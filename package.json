{
  "name": "vot-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "npm install --prefix server",
    "predev": "node -e \"const fs=require('fs'); if(!fs.existsSync('./server/.env')) fs.copyFileSync('./server/.env.example', './server/.env')\"",
    "dev": "npm run db:push --prefix server && concurrently \"vite\" \"npm run dev --prefix server\"",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0"
  }
}
