generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  osuId     Int      @unique
  username  String
  avatarUrl String?
  role      String   @default("PLAYER") // "PLAYER", "STAFF", "ADMIN"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stats             PlayerStat[]
  tournamentStaff   TournamentStaff[]
  tournamentPlayers TournamentPlayer[]
  lobbyPlayers      LobbyPlayer[]
}

model Tournament {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  shortName   String?  // e.g. "VOT6"
  description String?
  bannerImage String?
  accentColor String?  @default("#d92332") // Custom accent per tournament
  status      String   @default("upcoming") // "upcoming", "ongoing", "completed"
  startDate   String?
  endDate     String?
  rankMin     Int?
  rankMax     Int?
  rules       String?
  forumLink       String?
  twitchLink      String?
  spreadsheetLink String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  mappools    Mappool[]
  schedules   Schedule[]
  stats       PlayerStat[]
  staff       TournamentStaff[]
  players     TournamentPlayer[]
  bracketNodes BracketNode[]
  stageConfigs StageConfig[]
}

model TournamentStaff {
  id           Int        @id @default(autoincrement())
  userId       Int
  tournamentId Int
  staffRole    String     // "Host", "Mappooler", "Referee", "Streamer", "Commentator", "GFX"
  status       String     @default("pending") // "pending", "approved", "rejected"
  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([userId, tournamentId, staffRole])
}

model TournamentPlayer {
  id           Int        @id @default(autoincrement())
  userId       Int
  tournamentId Int
  discordId    String?
  discordName  String?
  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([userId, tournamentId])
}

model Mappool {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  stage        String     // "Qualifiers", "RO32", etc.
  mod          String     // "NM1", "HD1", etc.
  order        Int        @default(0)
  beatmapId    Int
  title        String
  artist       String
  mapper       String
  picker       String?
  diffName     String
  sr           Float
  od           Float
  hp           Float
  bpm          Float
  length       Int        @default(0)
  coverImage   String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model StageConfig {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  stage             String
  mappackUrl        String?
  mappoolPublished  Boolean    @default(false)
  schedulePublished Boolean    @default(false)
  
  @@unique([tournamentId, stage])
}

model Schedule {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  stage        String
  matchIdentifier String?
  type         String     @default("match") // "match" or "qualifier"
  date         String
  status       String     @default("upcoming") // "upcoming", "active", "completed"
  matchTime    DateTime?
  player1Id    Int?
  player2Id    Int?
  player1Name  String?
  player2Name  String?
  player1Avatar String?
  player2Avatar String?
  score1       Int?
  score2       Int?
  matchScores  MatchScore[]
  refereeId    Int?
  refereeName  String?
  streamer     String?
  commentators String?
  mpLink       String?
  rescheduleTime DateTime?
  rescheduleBy   String?
  rescheduleStatus String? // "pending", "accepted"
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  lobbyPlayers LobbyPlayer[]
}

model LobbyPlayer {
  id         Int      @id @default(autoincrement())
  scheduleId Int
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([scheduleId, userId])
}

model PlayerStat {
  id           Int        @id @default(autoincrement())
  userId       Int
  tournamentId Int
  user         User       @relation(fields: [userId], references: [id])
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  stage        String
  score        Int
  accuracy     Float
  misses       Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([userId, tournamentId, stage])
}

model MatchScore {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  stage        String
  scheduleId   Int
  beatmapId    Int
  playerName   String
  score        Int
  accuracy     Float
  count300     Int
  count100     Int
  count50      Int
  countMiss    Int
  createdAt    DateTime   @default(now())

  schedule     Schedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, beatmapId, playerName])
}

model Notification {
  id         Int      @id @default(autoincrement())
  targetUser String   // username
  message    String
  link       String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model BracketNode {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  bracketType  String     // "Winners", "Losers", "Grand Final"
  round        Int        // 1, 2, 3... (Used for columns)
  matchOrder   Int        // 1, 2, 3... (Used for rows within the column)
  player1      String?
  player2      String?
  score1       Int?
  score2       Int?
  isCompleted  Boolean    @default(false)
  
  bestOf            Int?
  matchIdentifier   String? 
  nextWinnerMatchId Int?
  nextLoserMatchId  Int?
  scheduleId        Int?      @unique

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
